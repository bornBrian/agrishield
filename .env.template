# AgriShield Environment Variables Template
# Copy to .env and fill in your credentials

# ============================================
# JAVA & RUNTIME
# ============================================
JAVA_HOME=/usr/lib/jvm/java-25-openjdk-amd64
JAVA_OPTS=-Xmx2G -Xms1G -Djava.net.preferIPv4Stack=true

# ============================================
# DATABASE (PostgreSQL 16)
# ============================================
DB_URL=jdbc:postgresql://localhost:5432/agrishield
DB_USER=agrishield_user
DB_PASSWORD=your-secure-database-password-here

# ============================================
# CACHE (Redis 7)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# OAUTH / SOCIAL LOGIN
# ============================================
# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=285893124141-7chp3u04870firvqu08pv1k0dmva9s1g.apps.googleusercontent.com

# Apple ID (not used - removed per user request)
APPLE_CLIENT_ID=

# ============================================
# SMS / NOTIFICATIONS (Twilio)
# ============================================
TWILIO_ENABLED=true
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
TWILIO_PHONE_NUMBER=+1234567890

# User phone numbers for SMS (optional - for demo/testing)
# Format: USER_PHONE_<email_escaped>
# Example: USER_PHONE_admin_at_agrishield_tz=+255700000001
USER_PHONE_admin_at_agrishield_tz=+255700000001
USER_PHONE_farmer_at_agrishield_tz=+255700000002
USER_PHONE_regulator_at_agrishield_tz=+255700000003

# ============================================
# AUTHENTICATION
# ============================================
# "live" - verifies real OAuth tokens
# "demo" - accepts email-like tokens for development
AUTH_SOCIAL_MODE=demo

# "true" - returns preview reset code in responses (development only)
# "false" - hides reset codes in production
AUTH_DEBUG_RESET_CODE=true

# ============================================
# DEPLOYMENT
# ============================================
DOMAIN=Agrishield.com
ENVIRONMENT=development
LOG_LEVEL=INFO

# ============================================
# OPTIONAL - MONITORING & LOGGING
# ============================================
# ElasticSearch (if using centralized logging)
ELK_ENABLED=false
ELK_HOST=localhost
ELK_PORT=9200

# Sentry (error tracking)
SENTRY_ENABLED=false
SENTRY_DSN=

# ============================================
# NOTES
# ============================================
# 1. Change all "your-xxxxx" values before deploying to production
# 2. Keep this file secure - contains credentials
# 3. Add .env to .gitignore to prevent accidental commits
# 4. Rotate credentials periodically
# 5. Use secrets manager (AWS Secrets, HashiCorp Vault) for production
